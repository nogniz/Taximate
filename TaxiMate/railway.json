{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./gradlew bootJar -x test"
  },
  "deploy": {
    "startCommand": "java -jar $(ls build/libs/*.jar | grep -v plain | head -1)",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
